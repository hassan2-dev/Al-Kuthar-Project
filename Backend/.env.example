# Database (SQLite for local dev). For PostgreSQL, change prisma/schema.prisma provider + URL.
DATABASE_URL="file:./dev.db"

# JWT (use a long random secret in production)
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=1d

# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Optional public base URL if bucket is public; otherwise signed URLs are used
R2_PUBLIC_BASE_URL=

# API
PORT=5000
