# PostgreSQL (create DB first, then adjust user/password/host)
# Example: postgresql://USER:PASSWORD@localhost:5432/DB_NAME?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/alkuthar?schema=public"

# JWT (use a long random secret in production)
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=1d

# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Set to true if PutObject fails or objects do not appear (some S3 clients need path-style)
R2_FORCE_PATH_STYLE=false
# Optional: when set, document downloads use direct URLs (no presign). When unset, signed S3 URLs are used.
# Dev: R2 dashboard → bucket → Settings → Public access → enable "Public Development URL" → paste e.g. https://pub-xxxx.r2.dev (rate-limited; not for production).
# Prod: connect a custom domain to the bucket and set that base URL here instead.
R2_PUBLIC_BASE_URL=

# API (must match Coolify Ports Exposes / proxy target)
PORT=3024
# Coolify monorepo: Base Directory must be "Backend" (Linux is case-sensitive; "backend" fails Nixpacks detect).
